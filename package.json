{
  "name": "video-compressor",
  "version": "1.0.0",
  "description": "Compressor de vídeos para uso interno (Windows e Mac)",
  "main": "dist-electron/main.js",
  "author": "ae.digital",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build && electron-builder",
    "build:mac": "tsc -p tsconfig.node.json && vite build && electron-builder --mac",
    "build:win": "tsc -p tsconfig.node.json && vite build && electron-builder --win",
    "preview": "vite preview"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "digital.ae.videocompressor",
    "productName": "Video Compressor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.video"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
